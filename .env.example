APP_NAME=multilingual-rag
ENVIRONMENT=local
LOG_LEVEL=INFO
API_PREFIX=/v1

# Embeddings: bge-m3 runs locally and free (default). Set to "openai" to use the API instead.
# Switching providers changes vector dimensions (1024 vs 1536) and requires a Chroma re-index.
EMBEDDING_PROVIDER=bge-m3
# torch device for bge-m3: blank = auto (CUDA if present). Set to "cpu" if the API and worker
# would otherwise both load the model onto one small GPU.
EMBEDDING_DEVICE=

# Generation: ANY OpenAI-compatible chat-completions endpoint. The provider is just a URL —
# switching costs one line here and zero code.
#
# Default: NVIDIA NIM — free key at https://build.nvidia.com (1000 credits, 40 req/min, no card).
GENERATION_BASE_URL=https://integrate.api.nvidia.com/v1
GENERATION_API_KEY=
# Model catalogs rotate, and free-tier models can be cold/overloaded (some just hang). If
# generation errors or times out, pick a current, responsive id from https://build.nvidia.com/models
# — the 8B below answers instantly; the 70B is higher quality but often slow on the free tier.
GENERATION_MODEL=meta/llama-3.1-8b-instruct
# Fail fast instead of blocking on a slow model (seconds).
GENERATION_TIMEOUT_SECONDS=60
#
# Alternatives — uncomment one instead of the NIM block above:
#   OpenRouter (free tier rotates):  https://openrouter.ai/api/v1     + a ":free" model slug
#   Groq:                            https://api.groq.com/openai/v1
#   Local Ollama (fully offline):    http://localhost:11434/v1        + e.g. qwen2.5:3b
#   OpenAI (paid):                   https://api.openai.com/v1        + e.g. gpt-4.1-mini

# Romanized-Indic queries: detect romanized Hindi (Hindi function words) and transliterate it to
# native script before embedding, so it matches the native-script index. Plain English is left
# untouched. Ships for Hindi.
#   google     = googletrans (default; best quality, free, but a network call per query),
#                falls back to rule-based on failure
#   indicxlit  = local neural model (offline, free; downloads a ~52M checkpoint)
#   rule-based = indic-transliteration (instant, offline, lower quality)
#   llm        = reuse the GENERATION endpoint (costs credits)
#   off        = disable
TRANSLITERATION_ENABLED=true
TRANSLITERATION_PROVIDER=google
# How to detect romanized Indic: word-list (default, fast, local, Hindi-only) | muril (MuRIL
# feature + multi-class LR head, LOCAL hi/kn/te, ~950 MB, no network) | google (detects the language
# via Google Translate, hi/kn/te, a network call per query). muril or google enable Kannada/Telugu.
TRANSLITERATION_DETECTOR=word-list
# Which romanized languages to transliterate. Default hi. kn/te need detector=muril or google.
# TRANSLITERATION_LANGUAGES=hi,kn,te

# Only needed when EMBEDDING_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_BATCH_SIZE=96

# Vector store: faiss (default — local per-user files, no server, avoids Chroma's multi-process
# read issue) or chroma.
VECTOR_STORE=faiss
FAISS_PERSIST_DIRECTORY=data/faiss
CHROMA_PERSIST_DIRECTORY=data/chroma
CHROMA_COLLECTION_NAME=multilingual_documents
RAW_DOCUMENT_DIRECTORY=data/raw
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/multilingual_rag
# Auth. In staging/production the app refuses to boot with this placeholder or a <32-byte secret.
# Generate a strong one:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
# Short-lived; the frontend refreshes via /v1/auth/refresh before expiry.
ACCESS_TOKEN_EXPIRE_MINUTES=30
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

CHUNK_SIZE_TOKENS=800
CHUNK_OVERLAP_TOKENS=120
RETRIEVAL_TOP_K=8

# Browser origins allowed to call the API (comma-separated).
CORS_ALLOW_ORIGINS=http://localhost:3000

# Embedding-model startup tuning — enable once bge-m3 is cached locally (faster boot & first query):
# WARM_EMBEDDINGS_ON_STARTUP=true
# HF_HUB_OFFLINE=true

# Frontend build arg — the URL the *browser* uses to reach the API (baked into the client bundle).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
